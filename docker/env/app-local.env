# Media server
PORT_NUM=8080
PORT_NUM_MEDIA=9000
PORT_NUM_OPERATOR=9000
ENV=local
MEDIA_SERVER_URL=https://media.dynlit.docker
OPERATOR_SERVER_URL=http://dynlit-operator:8080
OPERATOR_API_KEY=dynlit-ssl-static-key-local

# ── ACME / Let's Encrypt ──────────────────────────────────────────────────────
# Email registered with Let's Encrypt (required for issuance).
ACME_EMAIL=admin@example.com

# Set to "false" to use the production ACME directory.
# Default is "true" (staging) — safe for local/dev environments.
# WARNING: switch to false only when the domain is publicly routable.
ACME_STAGING=true

# Path inside the operator container where the ACME account key is persisted.
# Must survive container restarts → backed by the ssl volume mount.
ACME_ACCOUNT_KEY_PATH=/app/ssl/acme-account.key

# Directory where issued certificate files are written.
# {domain}.crt  ← full-chain PEM   (0644)
# {domain}.key  ← private key PEM  (0600)
SSL_DIR=/app/ssl

